<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks Condition="$(OS) == 'Windows_NT'">$(NetFrameworkMinimumSupportedVersion)</TargetFrameworks>
    <TargetFrameworks Condition="$(OS) != 'Windows_NT'">$(NetMinimumSupportedVersion)</TargetFrameworks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OpenTelemetry.Exporter.InMemory" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)\src\OpenTelemetry.Instrumentation.Remoting\OpenTelemetry.Instrumentation.Remoting.csproj" />
  </ItemGroup>

  <!-- Remove all the tests on non-Windows platforms since remoting is only supported for .NET Framework -->
  <ItemGroup Condition="$(OS) != 'Windows_NT'">
    <Compile Remove="**/*.cs" />
  </ItemGroup>

</Project>
