<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(SupportedNetTargets)</TargetFrameworks>
    <Description>Unit test project for OpenTelemetry ASP.NET Core instrumentation.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Razor.RuntimeCompilation" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing"/>
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Client" />
    <PackageReference Include="Microsoft.AspNetCore.TestHost" />
    <PackageReference Include="OpenTelemetry.Exporter.InMemory" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" />
    <PackageReference Include="Testcontainers" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)\src\OpenTelemetry.Instrumentation.AspNetCore\OpenTelemetry.Instrumentation.AspNetCore.csproj" />
    <ProjectReference Include="$(RepoRoot)\test\TestApp.AspNetCore\TestApp.AspNetCore.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(RepoRoot)\test\Shared\ContainerFixture.cs" Link="Includes\ContainerFixture.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\ContainerFixture{T}.cs" Link="Includes\ContainerFixture{T}.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\CustomTextMapPropagator.cs" Link="Includes\CustomTextMapPropagator.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\DockerHelper.cs" Link="Includes\DockerHelper.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\DockerPlatform.cs" Link="Includes\DockerPlatform.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\EnabledOnDockerPlatformFactAttribute.cs" Link="Includes\EnabledOnDockerPlatformFactAttribute.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\EventSourceTestHelper.cs" Link="Includes\EventSourceTestHelper.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\InMemoryEventListener.cs" Link="Includes\InMemoryEventListener.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\TestEventListener.cs" Link="Includes\TestEventListener.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\WeaverCollection.cs" Link="Includes\WeaverCollection.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\WeaverFixture.cs" Link="Includes\WeaverFixture.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\WeaverSpecificationTests.cs" Link="Includes\WeaverSpecificationTests.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\WeaverTelemetryVerifier.cs" Link="Includes\WeaverTelemetryVerifier.cs" />
    <Compile Include="$(RepoRoot)\test\Shared\XunitContainerFixture{T}.cs" Link="Includes\XunitContainerFixture{T}.cs" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="RouteTests\RoutingTestCases.json" LogicalName="RoutingTestCases.json" CopyToOutputDirectory="Always" />
    <EmbeddedResource Include="$(RepoRoot)\test\Shared\weaver.Dockerfile" LogicalName="weaver.Dockerfile" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyMetadata Include="RouteTestsPath" Value="$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)/RouteTests'))" />
  </ItemGroup>

</Project>
