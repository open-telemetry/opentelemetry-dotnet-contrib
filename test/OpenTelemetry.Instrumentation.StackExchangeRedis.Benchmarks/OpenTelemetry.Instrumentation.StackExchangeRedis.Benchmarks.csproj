<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(SupportedNetTargets)</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <Description>Benchmark project for OpenTelemetry .NET StackExchange.Redis instrumentation.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" />
    <PackageReference Include="OpenTelemetry" />
    <PackageReference Include="StackExchange.Redis" VersionOverride="2.12.14" />
    <PackageReference Include="Testcontainers.Redis" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)\src\OpenTelemetry.Instrumentation.StackExchangeRedis\OpenTelemetry.Instrumentation.StackExchangeRedis.csproj" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="*.Dockerfile" LogicalName="%(FileName)%(Extension)" />
  </ItemGroup>

</Project>
