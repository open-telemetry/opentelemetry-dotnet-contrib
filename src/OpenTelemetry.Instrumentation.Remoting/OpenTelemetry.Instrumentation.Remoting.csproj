<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(NetFrameworkMinimumSupportedVersion)</TargetFrameworks>
    <Description>.NET Remoting instrumentation for OpenTelemetry.</Description>
    <PackageTags>$(PackageTags);distributed-tracing;Remoting</PackageTags>
    <MinVerTagPrefix>Instrumentation.Remoting-</MinVerTagPrefix>
  </PropertyGroup>

  <!-- Do not run Package Baseline Validation as this package has never released a stable version.
  Remove this property once we have released a stable version and add PackageValidationBaselineVersion property. -->
  <PropertyGroup>
    <DisablePackageBaselineValidation>true</DisablePackageBaselineValidation>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="OpenTelemetry.Instrumentation.Remoting.Tests" PublicKey="$(StrongNamePublicKey)" />
  </ItemGroup>

</Project>
